{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "Mephisto Chess Extension",
  "description": "Next best move analysis for your favorite chess websites",
  "version": "3.1.73",
  "homepage_url": "https://github.com/AlexPetrusca/Mephisto",
  "author": "Alex Petrusca",
  "icons": {
    "16": "res/icons/icon16.png",
    "32": "res/icons/icon32.png",
    "48": "res/icons/icon48.png",
    "128": "res/icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "res/icons/icon16.png",
      "32": "res/icons/icon32.png",
      "48": "res/icons/icon48.png",
      "128": "res/icons/icon128.png"
    },
    "options_page": "src/options/options.html"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "permissions": [
    "debugger",
    "nativeMessaging",
    "storage",
    "offscreen"
  ],
  "background": {
    "service_worker": "src/scripts/background-script.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.chess.com/*",
        "*://lichess.org/*",
        "*://blitztactics.com/*",
        "*://taketaketake.com/*",
        "*://www.taketaketake.com/*",
        "*://tactics.chessbase.com/*"
      ],
      "js": [
        "lib/lru.min.js",
        "lib/chess.js",
        "src/scripts/config-store.js",
        "src/scripts/panel-board.js",
        "src/popup/popup.js",
        "src/scripts/content-script.js"
      ]
    },
    {
      "matches": [
        "*://taketaketake.com/*",
        "*://www.taketaketake.com/*"
      ],
      "js": [
        "src/scripts/tt-probe.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://tactics.chessbase.com/*"
      ],
      "js": [
        "src/scripts/cb-probe.js"
      ],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "host_permissions": [
    "http://localhost:8080/*",
    "http://localhost:9090/*"
  ],
  "default_locale": "en"
}
